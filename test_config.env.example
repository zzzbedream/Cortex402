# Copia este archivo a test_config.env y ajusta los valores.
# No subas test_config.env con secretos reales.

# URL publica de la VPS detras de Cloudflare Tunnel.
URL_VPS=https://tu-subdominio.cloudflare.com

# Endpoint de salud del middleware.
HEALTH_PATH=/health

# Endpoint protegido que responde 402 para iniciar el pago real.
COMPUTE_PATH=/api/compute
COMPUTE_METHOD=POST
COMPUTE_REQUEST_BODY={"task":"qa-e2e"}

# Endpoints de intencion/verificacion del middleware.
INTENT_PATH=/payment/intent
VERIFY_PATH=/payment/verify

# Opcional: endpoint admin para limpiar cache/estado previo.
# ADMIN_RESET_PATH=/admin/reset-cache

# Stellar Testnet
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
USDC_CODE=USDC
USDC_ISSUER=GBBD47IF6LWK7P7MDEVXWR7SDVQDU5KPF5AMDNH2FUAQNQYJ3Q37LWRC

# Cuenta maestra que paga USDC en tests.
MASTER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MERCHANT_WALLET=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MIN_MASTER_USDC=2

# Parametros de prueba
PAYMENT_AMOUNT=0.15
REQUEST_TIMEOUT_MS=10000
MAX_REQ_PER_MIN=90
POLL_CONFIRM_MS=10000
POLL_INTERVAL_MS=1000
SIGN_RETRY_MAX=3

# Test de memo expirado
EXPIRED_CHALLENGE_SECONDS=2
EXPIRED_CHALLENGE_WAIT_MS=3000

# Test de resiliencia de red
# Si defines este comando, la suite intenta interrumpir el tunnel real.
# Ejemplo Linux (ejecutado desde tu maquina local):
# TUNNEL_INTERRUPT_CMD=ssh user@205.164.114.78 "sudo systemctl stop cloudflared; sleep 5; sudo systemctl start cloudflared"
TUNNEL_INTERRUPT_CMD=

# Fallback para simular unreachable cuando no hay control remoto del tunnel.
UNREACHABLE_TEST_URL=https://nonexistent.invalid/health

# Salida del reporte
REPORT_PATH=./test_report.json
