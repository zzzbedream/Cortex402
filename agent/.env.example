# Cortex402 Agent — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# Set permissions: chmod 600 .env

# Middleware endpoint (MUST be HTTPS in production)
MIDDLEWARE_URL=https://cortex402.yourdomain.com

# Anthropic API key for the LLM
ANTHROPIC_API_KEY=sk-ant-...

# Stellar network
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Master account secret — used to sponsor USDC to new agent wallets
# Generate via: node -e "console.log(require('stellar-sdk').Keypair.random().secret())"
# SECURITY: This file must have permissions 600 (chmod 600 .env)
MASTER_SECRET=S...

# Optional: Reuse an existing agent wallet instead of generating a new one
# If set, the agent will skip keypair generation and use this secret
# AGENT_SECRET=S...

# Agent behaviour
REQUEST_TIMEOUT_MS=45000
MAX_RETRIES=2
LOG_LEVEL=info
